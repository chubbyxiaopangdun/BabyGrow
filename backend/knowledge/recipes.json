{
  "version": "1.0",
  "description": "BabyGrow 辅食食谱参考（6个月-3岁）",
  "source": "基于中国营养学会《中国居民膳食指南》、美国儿科学会辅食添加建议",
  "principles": {
    "first_foods": "高铁米粉 → 蔬菜泥 → 果泥 → 肉泥",
    "rule_one": "新食物每次只加一种，观察3天",
    "rule_two": "1岁前辅食不加盐、糖、蜂蜜",
    "rule_three": "辅食性状随月龄调整：稀糊 → 稠糊 → 碎末 → 小块 → 普通食物",
    "allergy_alert": "高致敏食物（蛋清、海鲜、花生）建议8个月后尝试"
  },
  "recipes": {
    "6-7": {
      "name": "6-7个月 辅食初体验",
      "description": "以尝为主，奶为主食",
      "meals": [
        {
          "id": "r_6_1",
          "name": "高铁米粉糊",
          "age": "6个月+",
          "ingredients": [
            {"name": "高铁米粉", "amount": "5g", "note": "约1平勺"},
            {"name": "温水", "amount": "50ml", "note": "50℃左右"}
          ],
          "steps": [
            "米粉慢慢加入温水中，边加边搅拌",
            "搅拌至稀糊状（类似酸奶）",
            "第一天喂1-2勺，逐渐增加"
          ],
          "tips": "不要用奶粉冲调，会太稠"
        },
        {
          "id": "r_6_2",
          "name": "南瓜泥",
          "age": "6个月+",
          "ingredients": [
            {"name": "南瓜", "amount": "50g"},
            {"name": "温水", "amount": "适量"}
          ],
          "steps": [
            "南瓜去皮去籽，切小块",
            "上锅蒸15分钟至软烂",
            "用勺子压成泥或用料理机打泥",
            "可加少量温水调稀"
          ],
          "tips": "南瓜含β胡萝卜素，营养丰富"
        },
        {
          "id": "r_6_3",
          "name": "土豆泥",
          "age": "6个月+",
          "ingredients": [
            {"name": "土豆", "amount": "50g"},
            {"name": "温水", "amount": "适量"}
          ],
          "steps": [
            "土豆去皮，切小块",
            "蒸15分钟至软烂",
            "压成泥，加少量温水调稀"
          ],
          "tips": "土豆是低敏食物，适合作为第一种蔬菜泥"
        },
        {
          "id": "r_6_4",
          "name": "胡萝卜泥",
          "age": "6个月+",
          "ingredients": [
            {"name": "胡萝卜", "amount": "50g"},
            {"name": "植物油", "amount": "几滴", "note": "加辅食油促进胡萝卜素吸收"}
          ],
          "steps": [
            "胡萝卜去皮，切小块",
            "蒸20分钟至软烂（胡萝卜较硬）",
            "打成泥，滴几滴植物油"
          ],
          "tips": "胡萝卜素需要油脂才能更好吸收"
        },
        {
          "id": "r_6_5",
          "name": "苹果泥",
          "age": "6个月+",
          "ingredients": [
            {"name": "苹果", "amount": "半个"}
          ],
          "steps": [
            "苹果去皮去核",
            "用勺子直接刮成泥",
            "或蒸5分钟后打成泥"
          ],
          "tips": "生的苹果泥更脆甜，蒸熟的更软糯"
        },
        {
          "id": "r_6_6",
          "name": "香蕉泥",
          "age": "6个月+",
          "ingredients": [
            {"name": "香蕉", "amount": "半根"}
          ],
          "steps": [
            "选择熟透的香蕉（表皮有黑点）",
            "去皮，用勺子压成泥",
            "直接喂食"
          ],
          "tips": "不要喂未熟透的香蕉，可能导致便秘"
        },
        {
          "id": "r_6_7",
          "name": "西兰花泥",
          "age": "6个月+",
          "ingredients": [
            {"name": "西兰花", "amount": "50g", "note": "只取花部分"},
            {"name": "植物油", "amount": "几滴"}
          ],
          "steps": [
            "西兰花用盐水浸泡10分钟",
            "洗净，掰成小朵",
            "焯水2分钟后蒸5分钟",
            "打成泥，滴植物油"
          ],
          "tips": "西兰花是超级蔬菜，富含维C和钙"
        },
        {
          "id": "r_6_8",
          "name": "山药泥",
          "age": "6个月+",
          "ingredients": [
            {"name": "山药", "amount": "50g"}
          ],
          "steps": [
            "山药去皮（戴手套防粘液）",
            "切小块蒸15分钟",
            "压成泥"
          ],
          "tips": "山药健脾养胃，适合肠胃弱的宝宝"
        }
      ]
    },
    "7-9": {
      "name": "7-9个月 辅食进阶",
      "description": "开始添加肉泥、蛋黄，辅食性状变稠",
      "meals": [
        {
          "id": "r_7_1",
          "name": "鸡胸肉泥",
          "age": "7个月+",
          "ingredients": [
            {"name": "鸡胸肉", "amount": "30g"}
          ],
          "steps": [
            "鸡肉去筋膜，切小块",
            "冷水下锅焯水去腥",
            "换水煮熟或蒸熟",
            "加少量温水打成泥"
          ],
          "tips": "鸡肉是优质蛋白，铁含量比红肉低"
        },
        {
          "id": "r_7_2",
          "name": "猪肝粉",
          "age": "7个月+",
          "ingredients": [
            {"name": "猪肝", "amount": "100g", "note": "补铁佳品"}
          ],
          "steps": [
            "猪肝切片，用清水浸泡1小时",
            "换水焯水去血沫",
            "另起一锅水煮熟",
            "捞出晾干，小火炒干",
            "打成粉保存"
          ],
          "tips": "猪肝铁含量高，每周1-2次即可"
        },
        {
          "id": "r_7_3",
          "name": "三文鱼泥",
          "age": "7个月+",
          "ingredients": [
            {"name": "三文鱼", "amount": "30g", "note": "选无刺部分"}
          ],
          "steps": [
            "三文鱼去皮去刺",
            "柠檬片腌制10分钟去腥",
            "蒸或煮熟",
            "打成泥"
          ],
          "tips": "三文鱼富含DHA，有益大脑发育"
        },
        {
          "id": "r_7_4",
          "name": "蛋黄泥",
          "age": "7个月+",
          "ingredients": [
            {"name": "鸡蛋", "amount": "1个"}
          ],
          "steps": [
            "鸡蛋冷水下锅煮10分钟",
            "取出蛋黄",
            "加少量温水或奶调成泥",
            "从1/8蛋黄开始尝试"
          ],
          "tips": "蛋清容易过敏，1岁后再尝试全蛋"
        },
        {
          "id": "r_7_5",
          "name": "牛肉泥",
          "age": "8个月+",
          "ingredients": [
            {"name": "牛肉", "amount": "30g", "note": "选里脊或腿肉"}
          ],
          "steps": [
            "牛肉去筋膜，切小块",
            "冷水浸泡去血水",
            "焯水后煮烂",
            "打成泥"
          ],
          "tips": "红肉铁含量高，吸收率好"
        },
        {
          "id": "r_7_6",
          "name": "青菜小米粥",
          "age": "8个月+",
          "ingredients": [
            {"name": "小米", "amount": "20g"},
            {"name": "青菜叶", "amount": "20g"},
            {"name": "植物油", "amount": "几滴"}
          ],
          "steps": [
            "小米洗净煮粥，煮至软烂",
            "青菜焯水后切碎",
            "粥里加青菜碎和植物油"
          ],
          "tips": "小米好消化，搭配蔬菜营养均衡"
        },
        {
          "id": "r_7_7",
          "name": "番茄烂面条",
          "age": "8个月+",
          "ingredients": [
            {"name": "宝宝面条", "amount": "20g"},
            {"name": "番茄", "amount": "半个"},
            {"name": "青菜叶", "amount": "少量"}
          ],
          "steps": [
            "番茄去皮切碎",
            "青菜切碎",
            "面条折短，煮软烂",
            "加入番茄和青菜煮片刻"
          ],
          "tips": "面条要煮得比成人吃的更软"
        },
        {
          "id": "r_7_8",
          "name": "鱼肉蔬菜粥",
          "age": "8个月+",
          "ingredients": [
            {"name": "大米", "amount": "20g"},
            {"name": "鳕鱼", "amount": "20g"},
            {"name": "胡萝卜", "amount": "10g"},
            {"name": "青菜", "amount": "10g"}
          ],
          "steps": [
            "大米煮粥",
            "鱼肉去刺，蒸熟",
            "胡萝卜蒸熟切碎",
            "青菜焯水切碎",
            "全部加入粥中煮片刻"
          ],
          "tips": "选择刺少的鱼类如鳕鱼、三文鱼"
        }
      ]
    },
